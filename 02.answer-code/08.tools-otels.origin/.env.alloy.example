# Grafana Alloy OTEL Collector 환경변수 설정
# 사용법:
# 1. 이 파일을 .env.alloy로 복사: cp .env.alloy.example .env.alloy
# 2. 실제 값으로 수정
# 3. 환경변수 로드: export $(cat .env.alloy | xargs)
# 4. 애플리케이션 실행: ./run-with-alloy.sh

# ============================================
# 필수 환경변수
# ============================================

# OpenAI API Key
OPEN_AI_KEY=sk-your-openai-api-key-here

# Weather API Key (선택사항)
WEATHER_API_KEY=your-weather-api-key-here

# ============================================
# Grafana Alloy OTLP 설정
# ============================================

# Alloy OTLP Endpoint (Ingress 도메인)
OTEL_EXPORTER_OTLP_ENDPOINT=https://alloy.skala25a.project.skala-ai.com

# OTLP 프로토콜 (http/protobuf 또는 grpc)
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Traces 엔드포인트 (선택사항 - 자동으로 /v1/traces가 추가됨)
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://alloy.skala25a.project.skala-ai.com/v1/traces

# Logs 엔드포인트 (선택사항 - 자동으로 /v1/logs가 추가됨)
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=https://alloy.skala25a.project.skala-ai.com/v1/logs

# 서비스 이름
OTEL_SERVICE_NAME=spring-ai-tools

# Resource Attributes (선택사항)
OTEL_RESOURCE_ATTRIBUTES=service.name=spring-ai-tools,service.version=1.0.0,deployment.environment=local

# ============================================
# 선택사항: Alloy 인증 (필요한 경우)
# ============================================

# Basic Auth가 필요한 경우
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64_encoded_credentials>

# Bearer Token이 필요한 경우
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <token>
