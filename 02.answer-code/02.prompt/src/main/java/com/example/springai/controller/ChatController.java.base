package com.example.springai.controller;

import lombok.extern.slf4j.Slf4j;
import org.springframework.ai.chat.client.ChatClient;
import org.springframework.ai.chat.messages.Message;
import org.springframework.ai.chat.messages.SystemMessage;
import org.springframework.ai.chat.messages.UserMessage;
import org.springframework.ai.chat.messages.AssistantMessage;
import org.springframework.ai.chat.prompt.Prompt;
import org.springframework.ai.chat.prompt.ChatOptions;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Controller;
import org.springframework.web.bind.annotation.*;

import jakarta.servlet.http.HttpSession;

import java.util.ArrayList;
import java.util.List;
import java.util.Map;
import java.util.HashMap;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.SerializationFeature;

@Slf4j
@Controller
public class ChatController {
    
    private final ChatClient chatClient;
    private final ObjectMapper objectMapper;

    public ChatController(ChatClient.Builder chatClient) {
        this.chatClient = chatClient.build();
        this.objectMapper = new ObjectMapper();
        this.objectMapper.enable(SerializationFeature.INDENT_OUTPUT);
    }
    
    /**
     * 메인 채팅 페이지
     */
    @GetMapping("/")
    public String index() {
        return "chat";
    }
    
    /**
     * 채팅 메시지 처리
     */
    @PostMapping("/api/chat")
    @ResponseBody
    public ResponseEntity<Map<String, String>> chat(@RequestBody Map<String, String> request, HttpSession httpSession) {
        String userInput = request.get("message");
        String conversationId = request.get("conversationId");
        
        log.info("Received chat request: {} (conversationId: {})", userInput, conversationId);
        log.info("=".repeat(80));
        
        // Prompt, UserMessage, SystemMessage, AssistantMessage 직접 선언하여 사용
        List<Message> messages = new ArrayList<>();
        
        // SystemMessage 생성
        String systemContent = "당신의 이름은 SKALA AI입니다. " +
            "날씨를 질문하면 항상 추운 여름이라고 대답하세요." +
            "SKALA 관련 단어가 나오면 무조건 짱이라고 대답하세요" + 
            "SKALA는 SK에서 하는 교육 기관입니다";
        SystemMessage systemMessage = new SystemMessage(systemContent);
        messages.add(systemMessage);
        
        System.out.println("[1. SystemMessage 생성]");
        System.out.println("  - Message Type: " + systemMessage.getMessageType());
        System.out.println("  - Class: " + systemMessage.getClass().getSimpleName());
        System.out.println("  - Content: " + systemContent);
        System.out.println("  - Message 객체: " + systemMessage.toString());
        if (systemMessage.getMetadata() != null && !systemMessage.getMetadata().isEmpty()) {
            System.out.println("  - Metadata: " + systemMessage.getMetadata());
        }
        System.out.println();
        
        // UserMessage 생성
        UserMessage userMessage = new UserMessage(userInput);
        messages.add(userMessage);
        
        System.out.println("[2. UserMessage 생성]");
        System.out.println("  - Message Type: " + userMessage.getMessageType());
        System.out.println("  - Class: " + userMessage.getClass().getSimpleName());
        System.out.println("  - Content: " + userInput);
        System.out.println("  - Message 객체: " + userMessage.toString());
        if (userMessage.getMetadata() != null && !userMessage.getMetadata().isEmpty()) {
            System.out.println("  - Metadata: " + userMessage.getMetadata());
        }
        System.out.println();
        
        // Prompt 생성 (메시지 리스트를 포함)
        Prompt prompt = new Prompt(messages);
        
        System.out.println("[3. Prompt 생성]");
        System.out.println("  - Prompt에 포함된 메시지 수: " + prompt.getInstructions().size());
        System.out.println("  - 전체 메시지 리스트:");
        for (int i = 0; i < prompt.getInstructions().size(); i++) {
            Message msg = prompt.getInstructions().get(i);
            System.out.println("    [" + (i + 1) + "] Type: " + msg.getMessageType() + ", Class: " + msg.getClass().getSimpleName());
            System.out.println("         Message: " + msg.toString());
        }
        System.out.println();
        
        // ChatOptions 설정
        ChatOptions chatOptions = ChatOptions.builder()
            .model("gpt-4o-mini")
            .temperature(1.5)
            .topP(0.9)
            .maxTokens(500)
            .build();
        
        System.out.println("[4. ChatOptions 설정]");
        System.out.println("  - ChatOptions 객체: " + chatOptions.toString());
        try {
            Map<String, Object> optionsMap = new HashMap<>();
            if (chatOptions.getModel() != null) {
                optionsMap.put("model", chatOptions.getModel());
            }
            if (chatOptions.getTemperature() != null) {
                optionsMap.put("temperature", chatOptions.getTemperature());
            }
            if (chatOptions.getTopP() != null) {
                optionsMap.put("topP", chatOptions.getTopP());
            }
            if (chatOptions.getMaxTokens() != null) {
                optionsMap.put("maxTokens", chatOptions.getMaxTokens());
            }
            System.out.println("  - Options 구조:");
            System.out.println(objectMapper.writeValueAsString(optionsMap));
        } catch (Exception e) {
            log.warn("  - Options 직렬화 실패: {}", e.getMessage());
        }
        log.info("");
        
        System.out.println("[5. ChatClient → LLM 요청 전송]");
        System.out.println("  - 전송할 Prompt 구조:");
        try {
            Map<String, Object> requestStructure = new HashMap<>();
            List<Map<String, Object>> messageList = new ArrayList<>();
            for (Message msg : prompt.getInstructions()) {
                Map<String, Object> msgMap = new HashMap<>();
                msgMap.put("type", msg.getMessageType().name());
                msgMap.put("class", msg.getClass().getSimpleName());
                msgMap.put("message", msg.toString());
                messageList.add(msgMap);
            }
            requestStructure.put("messages", messageList);
            
            Map<String, Object> optionsMap = new HashMap<>();
            if (chatOptions.getModel() != null) {
                optionsMap.put("model", chatOptions.getModel());
            }
            if (chatOptions.getTemperature() != null) {
                optionsMap.put("temperature", chatOptions.getTemperature());
            }
            if (chatOptions.getTopP() != null) {
                optionsMap.put("topP", chatOptions.getTopP());
            }
            if (chatOptions.getMaxTokens() != null) {
                optionsMap.put("maxTokens", chatOptions.getMaxTokens());
            }
            requestStructure.put("options", optionsMap);
            
            System.out.println(objectMapper.writeValueAsString(requestStructure));
        } catch (Exception e) {
            System.out.println("  - 요청 구조 직렬화 실패: " + e.getMessage());
        }
        System.out.println();
        
        // ChatClient에 Prompt의 메시지들과 ChatOptions 전달
        // Prompt 객체를 생성했으므로, Prompt에 포함된 메시지들을 사용
        String response = this.chatClient.prompt()
            .messages(prompt.getInstructions())
            .options(chatOptions)
            .call()
            .content();
        
        System.out.println("[6. LLM → ChatClient 응답 수신]");
        System.out.println("  - 응답 내용: " + response);
        System.out.println("");
        
        // 응답으로 받은 AssistantMessage도 생성 (참고용)
        AssistantMessage assistantMessage = new AssistantMessage(response);
        
        System.out.println("[7. AssistantMessage 생성]");
        System.out.println("  - Message Type: " + assistantMessage.getMessageType());
        System.out.println("  - Class: " + assistantMessage.getClass().getSimpleName());
        System.out.println("  - Content: " + response);
        System.out.println("  - Message 객체: " + assistantMessage.toString());
        if (assistantMessage.getMetadata() != null && !assistantMessage.getMetadata().isEmpty()) {
            System.out.println("  - Metadata: " + assistantMessage.getMetadata());
        }
        System.out.println();
        
        System.out.println("[8. 최종 응답 데이터]");
        System.out.println("  - 응답 메시지: " + response);
        System.out.println("  - 대화 ID: " + conversationId != null ? conversationId : httpSession.getId());
        System.out.println("=".repeat(80));

        Map<String, String> responseMap = new HashMap<>();
        responseMap.put("message", response);
        responseMap.put("conversationId", conversationId != null ? conversationId :  httpSession.getId());
        
        return ResponseEntity.ok(responseMap);
    }
    
    /**
     * 새 대화 시작
     */
    @PostMapping("/api/chat/new")
    @ResponseBody
    public ResponseEntity<String> newConversation() {
        String conversationId = java.util.UUID.randomUUID().toString();
        log.info("Created new conversation: {}", conversationId);
        return ResponseEntity.ok(conversationId);
    }

}
